OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TENANT_ID=common
OUTLOOK_REDIRECT_URI=http://localhost:8776/oauth/callback
OUTLOOK_OAUTH_SCOPES=offline_access openid profile User.Read Mail.Read Mail.ReadWrite Mail.Send MailboxSettings.Read Calendars.Read Calendars.ReadWrite
# Optional overrides. By default, tokens and local state live in your per-user state dir.
# OUTLOOK_OAUTH_TOKEN_FILE=
# OUTLOOK_MCP_INDEX_DB=
# OUTLOOK_RECEIVER_HOST=127.0.0.1
# OUTLOOK_RECEIVER_PORT=8777
# OUTLOOK_RECEIVER_PATH=/graph/notifications
# OUTLOOK_NOTIFICATION_URL=
# OUTLOOK_LIFECYCLE_NOTIFICATION_URL=
# OUTLOOK_NOTIFICATION_LOG_FILE=
